<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan.vien.form</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form string="Nhân viên">
                    <sheet>
                        <field name="anh" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <label for="ho_va_ten"/>
                            <h1>
                                <field name="ho_va_ten" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Thông tin cá nhân">
                                <field name="ma_dinh_danh"/>
                                <field name="ho_ten_dem"/>
                                <field name="ten"/>
                                <field name="gioi_tinh"/>
                                <field name="ngay_sinh"/>
                                <field name="tuoi" readonly="1"/>
                                <field name="so_nguoi_bang_tuoi" readonly="1"/>
                            </group>
                            <group string="Liên hệ và định danh">
                                <field name="so_cccd"/>
                                <field name="ngay_cap_cccd"/>
                                <field name="noi_cap_cccd"/>
                                <field name="que_quan"/>
                                <field name="dia_chi_lien_he"/>
                                <field name="email"/>
                                <field name="so_dien_thoai"/>
                            </group>
                        </group>
                        <group string="Thông tin công việc">
                            <field name="trang_thai"/>
                            <field name="ngay_vao_lam"/>
                            <field name="ngay_nghi_viec"/>
                            <field name="don_vi_hien_tai_id" readonly="1"/>
                            <field name="chuc_vu_hien_tai_id" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <notebook>
                            <page string="Lịch sử công tác">
                                <field name="lich_su_cong_tac_ids">
                                    <tree editable="bottom">
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="don_vi_id"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="loai_chuc_vu"/>
                                        <field name="dang_hieu_luc" readonly="1"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Chứng chỉ/Bằng cấp">
                                <field name="danh_sach_chung_chi_bang_cap_ids">
                                    <tree editable="bottom">
                                        <field name="chung_chi_bang_cap_id"/>
                                        <field name="so_hieu"/>
                                        <field name="noi_cap"/>
                                        <field name="ngay_cap"/>
                                        <field name="ngay_het_han"/>
                                        <field name="trang_thai" readonly="1"/>
                                        <field name="ten_tep" invisible="1"/>
                                        <field name="tep_dinh_kem" filename="ten_tep"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Ghi chú">
                                <field name="ghi_chu"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan.vien.tree</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree string="Nhân viên">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_va_ten"/>
                    <field name="gioi_tinh"/>
                    <field name="ngay_sinh"/>
                    <field name="tuoi"/>
                    <field name="so_dien_thoai"/>
                    <field name="email"/>
                    <field name="don_vi_hien_tai_id"/>
                    <field name="chuc_vu_hien_tai_id"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="nhan_vien_search">
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search string="Tìm nhân viên">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_va_ten"/>
                    <field name="so_cccd"/>
                    <field name="email"/>
                    <field name="so_dien_thoai"/>
                    <field name="don_vi_hien_tai_id"/>
                    <field name="chuc_vu_hien_tai_id"/>
                    <filter string="Đang làm việc" name="working" domain="[('trang_thai', '=', 'working')]"/>
                    <filter string="Đã nghỉ việc" name="resigned" domain="[('trang_thai', '=', 'resigned')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Đơn vị" name="group_don_vi" context="{'group_by': 'don_vi_hien_tai_id'}"/>
                        <filter string="Chức vụ" name="group_chuc_vu" context="{'group_by': 'chuc_vu_hien_tai_id'}"/>
                        <filter string="Trạng thái" name="group_trang_thai" context="{'group_by': 'trang_thai'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="nhan_vien_search"/>
        </record>
    </data>
</odoo>
