<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_don_vi_form" model="ir.ui.view">
            <field name="name">don.vi.form</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <form string="Đơn vị">
                    <sheet>
                        <group>
                            <field name="ma_don_vi"/>
                            <field name="ten_don_vi"/>
                            <field name="don_vi_cha_id"/>
                            <field name="so_luong_nhan_vien" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Mô tả">
                                <field name="mo_ta"/>
                            </page>
                            <page string="Nhân viên hiện tại">
                                <field name="nhan_vien_ids" readonly="1">
                                    <tree>
                                        <field name="ma_dinh_danh"/>
                                        <field name="ho_va_ten"/>
                                        <field name="chuc_vu_hien_tai_id"/>
                                        <field name="email"/>
                                        <field name="so_dien_thoai"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_don_vi_tree" model="ir.ui.view">
            <field name="name">don.vi.tree</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <tree string="Đơn vị">
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                    <field name="don_vi_cha_id"/>
                    <field name="so_luong_nhan_vien"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="don_vi_search">
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <search string="Tìm đơn vị">
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                    <field name="don_vi_cha_id"/>
                </search>
            </field>
        </record>

        <record id="action_don_vi" model="ir.actions.act_window">
            <field name="name">Đơn vị</field>
            <field name="res_model">don_vi</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="don_vi_search"/>
        </record>
    </data>
</odoo>
